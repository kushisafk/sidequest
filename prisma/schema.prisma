generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(cuid())
  name         String?
  githubId     String      @unique
  githubHandle String
  avatar       String?
  createdAt    DateTime    @default(now())
  projects     Project[]
  guestbooks   Guestbook[]
}

model Project {
  id          String      @id @default(cuid())
  name        String
  tagline     String
  description String
  techStack   String
  deathTags   String
  startDate   DateTime
  endDate     DateTime
  epitaph     String
  lessons     String
  githubUrl   String?
  websiteUrl  String?
  createdAt   DateTime    @default(now())
  resurrected Boolean     @default(false)
  authorId    String
  author      User        @relation(fields: [authorId], references: [id])
  guestbooks  Guestbook[]
}

model Guestbook {
  id         String   @id @default(cuid())
  message    String
  authorName String
  createdAt  DateTime @default(now())
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
